🔹 1. Import Libraries
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from scipy import stats
import statsmodels.api as sm
from sklearn.linear_model import LinearRegression
🔹 2. Load Dataset
sales = pd.read_csv("sales_data.csv")
churn = pd.read_csv("customer_churn.csv")

sales.head()
📊 DAY 1 – DESCRIPTIVE STATISTICS
sales.describe()
mean_sales = sales['Sales'].mean()
median_sales = sales['Sales'].median()
mode_sales = sales['Sales'].mode()[0]
std_sales = sales['Sales'].std()

print("Mean:", mean_sales)
print("Median:", median_sales)
print("Mode:", mode_sales)
print("Standard Deviation:", std_sales)
📊 DAY 2 – DATA DISTRIBUTION
plt.hist(sales['Sales'], bins=10)
plt.title("Sales Distribution")
plt.xlabel("Sales")
plt.ylabel("Frequency")
plt.show()
Normality Test
stat, p = stats.shapiro(sales['Sales'])
print("p-value:", p)

if p > 0.05:
    print("Data is normally distributed")
else:
    print("Data is NOT normally distributed")
📊 DAY 3 – CORRELATION ANALYSIS
correlation = sales.corr()
print(correlation)
sns.heatmap(correlation, annot=True)
plt.title("Correlation Heatmap")
plt.show()
📊 DAY 4 – HYPOTHESIS TESTING
🔹 Hypothesis 1: Marketing Spend affects Sales

H0: Marketing does not affect Sales
H1: Marketing affects Sales

corr, p_value = stats.pearsonr(sales['Marketing_Spend'], sales['Sales'])

print("Correlation:", corr)
print("p-value:", p_value)
🔹 Hypothesis 2: Region-wise Sales Difference (ANOVA)
stats.f_oneway(
    sales[sales['Region']=="North"]['Sales'],
    sales[sales['Region']=="South"]['Sales'],
    sales[sales['Region']=="East"]['Sales'],
    sales[sales['Region']=="West"]['Sales']
)
🔹 Hypothesis 3: Churn vs Non-Churn Revenue (t-test)
churn_yes = churn[churn['Churn']==1]['Revenue']
churn_no = churn[churn['Churn']==0]['Revenue']

stats.ttest_ind(churn_yes, churn_no)
📊 DAY 5 – CONFIDENCE INTERVAL
confidence = 0.95
mean = np.mean(sales['Sales'])
sem = stats.sem(sales['Sales'])
interval = stats.t.interval(confidence, len(sales['Sales'])-1, loc=mean, scale=sem)

print("95% Confidence Interval:", interval)
📊 DAY 6 – REGRESSION ANALYSIS
X = sales[['Marketing_Spend']]
y = sales['Sales']

model = LinearRegression()
model.fit(X, y)

r_squared = model.score(X, y)

print("R-squared:", r_squared)
print("Coefficient:", model.coef_)
📊 DAY 7 – BUSINESS INSIGHTS
print("Average Sales:", round(mean,2))
print("Confidence Interval:", interval)
print("Marketing Impact Correlation:", round(corr,2))
print("R-squared:", round(r_squared,2))
